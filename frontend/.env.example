VITE_PAYPAL_CLIENT_ID=...
VITE_API_URL=http://localhost:8000/api

# Dev only (`npm run dev`). Docker + nginx does not use this.
# DEV_PUBLIC_ORIGIN=http://YOUR_IP:5173

# Docker image: VITE_* is baked in at `docker build`. Pass build-args or put the same
# keys in a .env next to docker-compose.yml, then: docker compose --env-file .env up --build frontend