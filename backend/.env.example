# Docker does not load this file automatically. Pass it at run time, e.g.:
#   docker run ... --env-file .env ...
# Or: docker compose up (see repo root docker-compose.yml).

# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database - MySQL
DB_NAME=buocchancoi_db
DB_USER=root
DB_PASSWORD=your-password-here
DB_HOST=localhost
DB_PORT=3306

# Cloudinary
CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name

# PayPal (Sandbox)
PAYPAL_CLIENT_ID=...
PAYPAL_SECRET=...
PAYPAL_BASE=https://api-m.sandbox.paypal.com

# Partner premium unlock fee is now managed in Django Admin: Payments > Cấu hình thanh toán

# When the SPA is served from another origin (e.g. http://PUBLIC_IP:3000), add it here (comma-separated).
# CORS_EXTRA_ORIGINS=http://YOUR_PUBLIC_IP,http://YOUR_PUBLIC_IP:3000
# CSRF_TRUSTED_ORIGINS_EXTRA=http://YOUR_PUBLIC_IP,http://YOUR_PUBLIC_IP:3000

# Local dev: default `manage.py runserver` listens on 127.0.0.1 only (browser shows localhost).
# Use: ./run-dev.sh   or:  python manage.py runserver 0.0.0.0:8000

# Payment redirects must use a URL phones/gateways can call (not localhost):
# VNPAY_RETURN_URL=http://YOUR_PUBLIC_IP:8000/api/payments/vnpay-return/
# VNPAY_IPN_URL=http://YOUR_PUBLIC_IP:8000/api/payments/vnpay-ipn/
# VNPAY_FRONTEND_RETURN_URL=http://YOUR_PUBLIC_IP/payment/vnpay-return

# Caddy/nginx terminates HTTPS (docker compose + Caddyfile)
# BEHIND_HTTPS_PROXY=true
