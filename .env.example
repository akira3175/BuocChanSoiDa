# Copy to ".env" in this repo root (same folder as docker-compose.yml).
# docker compose reads it automatically for ${VAR} substitution.

# --- HTTPS (Caddy + Let's Encrypt) ---
# DNS: A record for DOMAIN → your EC2 public IP. AWS SG: inbound TCP 80 + 443.
DOMAIN=foodstreet.alixblu.site
ACME_EMAIL=your-email@example.com

# --- Frontend build (must be https:// + this same host) ---
VITE_API_URL=https://foodstreet.alixblu.site/api
VITE_PAYPAL_CLIENT_ID=
VITE_PUBLIC_BASE_URL=https://foodstreet.alixblu.site
